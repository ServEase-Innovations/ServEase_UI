# Copy to .env.local. Restart the dev server after changes.
# See `src/config/urls.ts` for a full table of which env maps to which API.

# — payments: engagements, payments, in-app notifications, Socket.IO (port 4100 in monorepo)
REACT_APP_PAYMENTS_URL=http://localhost:4100
# REACT_APP_SOCKET_URL=http://localhost:4100   # optional legacy alias of the same base

# — providers: e.g. POST /api/customer, provider API (port 4000)
# REACT_APP_PROVIDER_URL=http://localhost:4000
# REACT_APP_URL=                                    # same as PROVIDER in some old setups

# — preferences: user settings / saved locations (port 3001)
# REACT_APP_PREFERENCES_URL=http://localhost:3001

# — utils: check-email, /records, etc. (port 3030)
# REACT_APP_UTILS_URL=http://localhost:3030
# REACT_APP_UTLIS_URL=                              # typo used in some envs; urls.ts supports it
# REACT_APP_UTILS_WS_URL=                           # raw wss to utils; if empty, derived from REACT_APP_UTILS_URL

# — reviews (port 5005) — not imported in many screens yet; instance exists
# REACT_APP_REVIEWS_URL=http://localhost:5005

# — coupons (port 3002) — `urls.coupons` only; add a couponsInstance when you need it
# REACT_APP_COUPONS_URL=http://localhost:3002

# Not used in code: REACT_APP_API_URL (no single "servease-be" backend; set each service above or a gateway per path)
