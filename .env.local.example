# Point at Render DEV backends (or localhost — see comments). Restart `npm start` after edits.
# See `src/config/urls.ts` for which variable feeds which client.

REACT_APP_ENV=qa

# payments — HTTP + Socket.IO
REACT_APP_PAYMENTS_URL=https://payments-vyqp.onrender.com
REACT_APP_SOCKET_URL=https://payments-vyqp.onrender.com

# providers
REACT_APP_URL=https://providers-k8w7.onrender.com
REACT_APP_PROVIDER_URL=https://providers-k8w7.onrender.com

# preferences
REACT_APP_PREFERENCES_URL=https://preferences.onrender.com

# utils — check-email, platform settings, Auth0 user create (/authO)
REACT_APP_UTILS_URL=https://utils-jo6c.onrender.com
REACT_APP_ADMIN_PUSH_SECRET=serveaso-test-push-secret
# REACT_APP_UTLIS_URL=                              # typo alias; urls.ts supports it
# REACT_APP_UTILS_WS_URL=                           # raw wss to utils; if empty, derived from REACT_APP_UTILS_URL

# reviews
REACT_APP_REVIEWS_URL=https://reviews-7aal.onrender.com

# coupons
REACT_APP_COUPONS_URL=https://coupons-o26r.onrender.com

# tickets
REACT_APP_TICKETS_URL=https://tickets-3gc8.onrender.com

# chat — support widget
REACT_APP_CHAT_URL=https://chat-b3wl.onrender.com

# image uploader — SP registration profile/KYC uploads
REACT_APP_IMAGE_UPLOADER_URL=https://imageuploader-5njj.onrender.com

# tracking — provider journey tracking
REACT_APP_TRACKING_API_URL=http://localhost:5007/api/tracking
REACT_APP_TRACKING_WS_URL=http://localhost:5007

# Auth0 (dev tenant)
# REACT_APP_AUTH0_DOMAIN=
# REACT_APP_AUTH0_CLIENT_ID=
# REACT_APP_AUTH0_AUDIENCE=

