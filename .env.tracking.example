# Tracking Service Configuration
# Copy this to your .env file and configure

# Tracking API Base URL
# Local: http://localhost:5007/api/tracking
# Production: https://notifications-mjdp.onrender.com/api/tracking
REACT_APP_TRACKING_API_URL=http://localhost:5007/api/tracking

# Tracking WebSocket URL
# Local: http://localhost:5007
# Production: https://notifications-mjdp.onrender.com
REACT_APP_TRACKING_WS_URL=http://localhost:5007

# Google Maps API Key (required for maps display)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
