# Local: point at `npm run dev` backends from the Serveaso-BE monorepo. Restart `npm start` after edits.
# See `src/config/urls.ts` for which variable feeds which client.

REACT_APP_ENV=local

# payments — HTTP + Socket.IO (monorepo PORT=4100)
REACT_APP_PAYMENTS_URL=http://localhost:4100
REACT_APP_SOCKET_URL=http://localhost:4100

# providers — `REACT_APP_URL` and `REACT_APP_PROVIDER_URL` (monorepo PORT=4000)
REACT_APP_URL=http://localhost:4000
REACT_APP_PROVIDER_URL=http://localhost:4000

# preferences (PORT=3001)
REACT_APP_PREFERENCES_URL=http://localhost:3001

# utils — pricing `/records`, check-email, etc. (PORT=3030)
REACT_APP_UTILS_URL=http://localhost:3030

# optional typo alias (supported in urls.ts); can delete if you use REACT_APP_UTILS_URL only
REACT_APP_UTLIS_URL=http://localhost:3030

# reviews (PORT=5005)
REACT_APP_REVIEWS_URL=http://localhost:5005

# coupons (PORT=3002)
REACT_APP_COUPONS_URL=http://localhost:3002

# Not read by this app: generic API host (kept for documentation only; leave blank or remove)
# REACT_APP_API_URL=
